/* Reset básico de estilos */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    line-height: 1.6;
    color: #333;
    background-color: #f4f9f4;
}

/* Cabeçalho */
.main-header {
    background-color: #2e7d32;
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 5%;
    position: sticky;
    top: 0;
    z-index: 100;
}

.main-header ul {
    display: flex;
    list-style: none;
}

.main-header a {
    color: white;
    text-decoration: none;
    padding: 0.5rem 1rem;
    font-weight: bold;
}

/* Seção Principal (Hero) */
.hero-section {
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://unsplash.com') no-repeat center center/cover;
    color: white;
    text-align: center;
    padding: 5rem 1rem;
}

.hero-section h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.btn-primary {
    display: inline-block;
    background-color: #ff9800;
    color: white;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    margin-top: 1rem;
}

/* Seções de Conteúdo */
section {
    padding: 3rem 5%;
    text-align: center;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
}

.card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    border-top: 5px solid #4caf50;
}

/* Simulador Interativo */
.game-container {
    background: #e8f5e9;
    padding: 2rem;
    border-radius: 10px;
    max-width: 600px;
    margin: 2rem auto 0;
    border: 2px dashed #2e7d32;
}

.actions {
    margin: 1.5rem 0;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-choice {
    background-color: #2e7d32;
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    border-radius: 4px;
    font-size: 0.9rem;
    transition: 0.2s;
}

.btn-choice:hover {
    background-color: #1b5e20;
}

.feedback-text {
    font-weight: bold;
    margin-top: 1rem;
    font-size: 1.1rem;
}

/* Rodapé */
.main-footer {
    background-color: #1b5e20;
    color: white;
    text-align: center;
    padding: 1rem;
    font-size: 0.9rem;
}
